	)
	(text "LS09- 2 INPUT AND GATE\nLS32- 2 INPUT OR GATE\n4075- 3 INPUT OR GATE\nHC02- 2 INPUT NOR GATE\nHC04- NOT GATE"
		(exclude_from_sim no)
		(at 147.32 130.81 0)
		(effects
