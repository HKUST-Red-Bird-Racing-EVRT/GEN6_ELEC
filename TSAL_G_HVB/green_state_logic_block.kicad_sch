			)
			(justify left)
		)
		(uuid "9b99c012-cf1e-4054-a5bf-95bd099cc626")
	)
	(text "Boolean Algebra for TSAL Green Logic:\n\nGREEN_STATE =1, GREEN LIGHT ON STATE\nLATCH_STATE=1,  TRIGGER GREEN LIGHT OFF LATCH, RESET BY POWER CYCLE ONLY\n\nSCS OK, SCS_SIGN = 1\nTS Voltage < 60, V_SIGN=1\nIf Relay closed, both Intentional and auxiliary signal =1\n"
		(exclude_from_sim no)
		(at 38.1 147.32 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
			(justify left)
		)
		(uuid "b2b29602-d199-4333-960e-40650eeb9dd0")
	)
	(text "F(GREEN_STATE)=\n(AIRH)'*(AIRL)'*(PRECHARGE)'*SCS_SIGN*V_SIGN"
