	(text "F(LATCH_STATE)=\nAIRH*(AIRH_AUX)'+AIRL*(AIRL_AUX)'+PRECHARGE*(PRECHARGE_AUX)'+(SCS_SIGN)'+AIRH*V_SIGN+AIRL*V_SIGN+PRECHARGE*V_SIGN\n=\nAIRH*((AIRH_AUX)'+V_SIGN)+AIRL*((AIRL_AUX)'+V_SIGN)+PRECHARGE*((PRECHARGE)'+V_SIGN)+(SCS_SIGN)'"
		(exclude_from_sim no)
		(at 31.75 152.4 0)
		(effects
			(font
				(size 2.54 2.54)
				(thickness 0.1778)
				(bold yes)
			)
			(justify left)
		)
		(uuid "075c1ca4-1792-4ef5-8ea3-d7975765f767")
	)
	(text "LS09- 2 INPUT AND GATE\nLS32- 2 INPUT OR GATE\n4075- 3 INPUT OR GATE\nHC02- 2 INPUT NOR GATE\nHC04- NOT GATE"
		(exclude_from_sim no)
		(at 31.75 173.99 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "0b9d291f-f49c-47f6-80d4-fded330a5c5f")
	)
	(text "S = SCS_SIGN\nV = V_SIGN\nH = AIR_H\nL = AIR_L\nP = PRECHARGE\nHA = AIRH_AUX\nLA = AIRL_AUX\nPA = PRECHARGE_AUX\nL_S = LATCH_STATE\nG_S = GREEN_STATE"
		(exclude_from_sim no)
		(at 63.5 176.53 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
			(justify left)
		)
		(uuid "3543e36e-111e-41ad-831f-8d5ada9810a7")
	)
	(text "Boolean Algebra for TSAL Green Logic:\n\nGREEN_STATE =1, GREEN LIGHT ON STATE\nLATCH_STATE=1,  TRIGGER GREEN LIGHT OFF LATCH, RESET BY POWER CYCLE ONLY\n\nSCS OK, SCS_SIGN = 1\nTS Voltage < 60, V_SIGN=1\nIf Relay closed, both Intentional and auxiliary signal =1\n"
		(exclude_from_sim no)
		(at 91.44 175.26 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
			(justify left)
		)
		(uuid "df46dc19-f2dc-4736-9391-d04be3161832")
	)
